									"    pm.expect(response.data.status).to.eql('successful');",
									"    pm.expect(response.data.method).to.eql('credit_card');",
									"    pm.expect(response.data.transaction_id).to.not.be.null;",
									"});"
								],
								"type": "text/javascript"
